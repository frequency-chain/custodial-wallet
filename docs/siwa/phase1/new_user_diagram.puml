@startuml
title "New User Flow"
actor "User" as u
participant "UserAgent" as ua
participant "Provider" as p
participant "Frequency\nAccess" as fa
database "Postgres" as db
database "Redis" as r
participant "Frequency" as bc
participant "SES" as ses
participant "Notification\nService" as ns

note across: Assumes you are coming from the Login Flow
autonumber
     group Identifier Verification
        fa->fa: Generate authenticationCode
        fa->r: Persist Session by authenticationCode and sessionId
        return
        alt isEmail
            fa->ses: Send Email (sessionId and authenticationCode)
            ses->u: Email sent
            u->fa: User Clicks Email
            fa->r: find Session by authenticationCode and sessionId
            return Session
        else isSms
            fa->ns: Send SMS
            fa->ua: Display SMS Form
            ns->u: Sms Message received
            u->ua: Enters authenticationCode
            ua->fa: Submits authenticationCode
            fa->r: find Session by authenticationCode and sessionId
            return Session
        end
    end
    group Captured Data Path
        fa->fa: Single Selection of UserIdentifier to be sent to Provider
        fa->fa: Dereference permissions to I18N Verbiage
        fa->ua: Capture Form and Permissions with data identifiers to be sent to provider
        ua->fa: Acceptance and Submit Data w/Identifier to send
        fa->r: find Session by Id
        return Session
        fa->fa: saveNewUserData for UserIdentifier
        fa->db: creates a new FA Account and associated data
        return  userKeyData
        fa->fa: Using UserKeyData create and sign appropriate\n payloads for permissions
        fa->fa: Add signedPayloads to Session
        fa->r: Update Session by Id
        return
        fa->fa: Single Selection of UserIdentifier to return to Provider to Session
        fa->fa: Generate authorizationCode
        fa->r: update Session by id, authorizationCode
        return
    end
    fa->ua: Redirect to callback url with authorizationCode, sessionId
    ua->p: Resolve redirect
    p->fa: Resolve payload by authorizationCode and sessionId
    fa->r: find Session bt authorizationCode and sessionId
    return
    fa->p: Signed Payload
@enduml
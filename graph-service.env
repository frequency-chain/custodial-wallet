DEBOUNCE_SECONDS=10
GRAPH_ENVIRONMENT_TYPE=Mainnet

# The encryption key seed below can be anything and any sufficiently sized random 
# value should work, but it needs to be a secret. While you might want to generate the 
# seed using https://iancoleman.io/bip39, it will work with any secret random value.
AT_REST_ENCRYPTION_KEY_SEED='This should get injected as a secret'
CACHE_KEY_PREFIX='graph-service:'
